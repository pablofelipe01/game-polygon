# Solo servidor (API routes) — NUNCA exponer al cliente
MASTER_WALLET_PRIVATE_KEY=tu_clave_privada_aqui
FG_TOKEN_ADDRESS=0x_direccion_del_contrato_FGToken
GAME_PASS_ADDRESS=0x_direccion_del_contrato_GamePass

# Cliente + Servidor (prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_FG_TOKEN_ADDRESS=0x_direccion_del_contrato_FGToken
NEXT_PUBLIC_GAME_PASS_ADDRESS=0x_direccion_del_contrato_GamePass
NEXT_PUBLIC_RPC_URL=https://polygon-rpc.com
NEXT_PUBLIC_CHAIN_ID=137
